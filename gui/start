#!/usr/bin/env bash
# Statscrypt Suite - Bootstrap installer
# Works on Windows (Git Bash), macOS, and Linux
# Installs just (task runner) if not already installed, then runs the app

set -e

echo "==========================================="
echo "  Statscrypt Suite - Bootstrap"
echo "==========================================="
echo ""

# Check if just is installed
if ! command -v just &> /dev/null; then
    echo "[*] 'just' task runner not found. Installing..."
    echo ""

    OS=$(uname -s)

    case "$OS" in
        Linux*)
            echo "Installing just for Linux..."
            curl --proto '=https' --tlsv1.2 -sSf https://just.systems/install.sh | bash -s -- --to ~/.local/bin
            export PATH="$HOME/.local/bin:$PATH"
            ;;
        Darwin*)
            echo "Installing just for macOS..."
            if command -v brew &> /dev/null; then
                brew install just
            else
                curl --proto '=https' --tlsv1.2 -sSf https://just.systems/install.sh | bash -s -- --to ~/.local/bin
                export PATH="$HOME/.local/bin:$PATH"
            fi
            ;;
        MINGW*|MSYS*|CYGWIN*)
            echo "Installing just for Windows..."
            curl --proto '=https' --tlsv1.2 -sSf https://just.systems/install.sh | bash -s -- --to AppData\Local\Bin
            ;;
        *)
            echo "Unsupported OS: $OS"
            echo "Please install 'just' manually from: https://github.com/casey/just"
            exit 1
            ;;
    esac

    if ! command -v just &> /dev/null; then
        echo "[!] Installation may have failed. Please install 'just' manually:"
        echo "    https://github.com/casey/just#installation"
        exit 1
    fi

    echo "[OK] just installed successfully"
    echo ""
fi

echo "[OK] just found: $(just --version)"
echo ""
echo "Starting Statscrypt Suite..."
echo ""

cd "$(dirname "$0")"
just start
